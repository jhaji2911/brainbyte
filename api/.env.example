# BrainByte API environment variables
# Copy this to .env and fill in values for production.

# Address the API listens on (default: 127.0.0.1:8080)
# Set to 0.0.0.0:8080 to accept connections from the emulator / device.
# API_HOST=127.0.0.1:8080

# ─── CMS Integration ───────────────────────────────────────
# URL of the Payload CMS instance.
CMS_API_URL=http://localhost:3000

# Shared secret for POST /cms/sync — must match the value in cms/.env
CMS_SYNC_SECRET=dev-sync-secret
